<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/padding_medium">

    <TextView
        android:id="@+id/textDetailDayNumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="@dimen/day_size_medium"
        android:textStyle="bold"
        android:gravity="start"
        android:padding="@dimen/padding_medium"/>

    <TextView
        android:id="@+id/textDetailTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="@dimen/title_size_medium"
        android:padding="@dimen/padding_medium"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <ScrollView
            android:layout_width="@dimen/zero_width"
            android:padding="@dimen/padding_medium"
            android:layout_weight="1"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/textDetailFullDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/description_size_medium"
                android:lineSpacingExtra="@dimen/line_spacing_extra"/>
        </ScrollView>

        <ImageView
            android:id="@+id/detailImage"
            android:padding="@dimen/padding_medium"
            android:layout_width="@dimen/zero_width"
            android:layout_height="match_parent"
            android:layout_weight="1.5"
            android:scaleType="centerCrop"
            android:importantForAccessibility="no"/>

    </LinearLayout>

</LinearLayout>